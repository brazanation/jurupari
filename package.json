{
  "name": "jurupari",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @jurupari/core prisma:generate",
    "db:migrate": "pnpm --filter @jurupari/core prisma:migrate",
    "db:push": "pnpm --filter @jurupari/core prisma:push",
    "db:deploy": "pnpm --filter @jurupari/core prisma:deploy",
    "dev:api": "pnpm --filter @jurupari/api dev",
    "dev:mcp": "pnpm --filter @jurupari/mcp dev"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
